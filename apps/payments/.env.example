# Payments service — local dev env. Copy this file to `.env` (same folder) and
# fill in your Stripe test-mode values. `.env` is git-ignored; this template is
# committed. Loaded by src/load-env.ts before the app starts. Real environment
# variables (e.g. docker-compose) always take precedence over anything set here.

# REQUIRED to reach Stripe's hosted checkout. Get it from the Stripe Dashboard →
# Developers → API keys, in TEST mode (starts with `sk_test_`). Without a valid
# key the "Pay with card" button returns a 502 ("couldn't reach the card
# payment provider").
STRIPE_SECRET_KEY=sk_test_replace_me

# OPTIONAL for reaching checkout, REQUIRED for orders to actually confirm. The
# signed webhook is the source of truth (ADR-0008): until it's received, a paid
# order stays "confirming…" and never flips to paid/cancelled. Run the Stripe CLI
#   stripe listen --forward-to localhost:3000/payments/webhook
# and paste the `whsec_...` it prints here. That secret is STABLE across CLI runs
# for your account — set it once; it does not change every time you start the app.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional overrides (sensible dev defaults exist for all of these):
# WEB_URL=http://localhost:3010        # where Stripe redirects back after checkout
# CATALOG_URL=http://localhost:3002
# ORDERS_URL=http://localhost:3003
# DATABASE_URL=postgres://payments:payments@localhost:55434/payments
