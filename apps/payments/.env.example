# Payments service secrets. Copy this file to `.env` (same folder) and fill in
# your Stripe test-mode values. `.env` is git-ignored (never committed, never
# baked into the Docker image); this template is committed.
#
# ONE file, both runtimes:
#   • `pnpm dev`        → loaded by src/load-env.ts before the app starts.
#   • `docker compose`  → loaded via `env_file: apps/payments/.env` (full profile).
# Real environment variables always win over this file: under docker-compose the
# `environment:` block overrides DATABASE_URL/CATALOG_URL/ORDERS_URL/WEB_URL with
# the in-cluster hostnames, so leave those commented out here (they're dev-only).

# REQUIRED to reach Stripe's hosted checkout. Prefer a TEST-mode *restricted* key
# (starts with `rk_test_`) over a full secret key (`sk_test_`): Stripe Dashboard →
# Developers → API keys → Create restricted key, granting only "Checkout Sessions:
# Write" (all this service does is open Checkout Sessions), so a leaked key can do
# far less damage. A plain `sk_test_` key also works. Without a valid key the "Pay
# with card" button returns a 502 ("couldn't reach the card payment provider").
STRIPE_SECRET_KEY=rk_test_replace_me

# OPTIONAL for reaching checkout, REQUIRED for orders to actually confirm. The
# signed webhook is the source of truth (ADR-0008): until it's received, a paid
# order stays "confirming…" and never flips to paid/cancelled. Run the Stripe CLI
#   stripe listen --forward-to localhost:3000/payments/webhook
# and paste the `whsec_...` it prints here. That secret is STABLE across CLI runs
# for your account — set it once; it does not change every time you start the app.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional overrides (sensible dev defaults exist for all of these):
# WEB_URL=http://localhost:3010        # where Stripe redirects back after checkout
# CATALOG_URL=http://localhost:3002
# ORDERS_URL=http://localhost:3003
# DATABASE_URL=postgres://payments:payments@localhost:55434/payments
